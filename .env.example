# GEMINI_API_KEY: Optional fallback key for Gemini AI API calls if OpenRouter is not used.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Required key for OpenRouter API calls.
# Switched as the default AI provider using model ID google/gemma-4-31b-it:free.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# NANSEN_API_KEY: Optional API key for authenticating with Nansen API endpoints.
# This powers real-time Smart Money Netflows, Holdings, DEX Trades and Address Profiling.
NANSEN_API_KEY=""

# MANTLESCAN_API_KEY or ETHERSCAN_API_KEY: Optional API key for querying Mantle block explorer (MantleScan / Routescan)
# This enables unlimited on-chain transaction logs and discovery.
MANTLESCAN_API_KEY=""
ETHERSCAN_API_KEY=""

# MANTLE_RPC_URL: Optional custom JSON-RPC endpoint for Mantle Mainnet. Defaults to 'https://rpc.mantle.xyz'
MANTLE_RPC_URL="https://rpc.mantle.xyz"

# Deployed ChameleonAI contract address on Mantle Mainnet
CHAMELEON_CONTRACT_ADDRESS=""

# Private key of the wallet holding the AI_OPERATOR_ROLE (Warning: never commit actual keys)
CHAMELEON_OPERATOR_PRIVATE_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
